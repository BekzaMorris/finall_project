    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^3.12.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
