# Database connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kiroportal?schema=public"

# Redis connection
REDIS_URL="redis://localhost:6379"

# JWT secrets
JWT_ACCESS_SECRET="your-access-token-secret-here"
JWT_REFRESH_SECRET="your-refresh-token-secret-here"

# Server
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:3000"

# S3/MinIO
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="kiroportal"

# SMTP
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@kiroportal.com"

# Sentry (optional)
SENTRY_DSN=""

ITOP_ENABLED=true
ITOP_URL=
ITOP_AUTH_USER=
ITOP_AUTH_PWD=
ITOP_TICKET_CLASS=UserRequest