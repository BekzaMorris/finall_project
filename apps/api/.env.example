# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kiroportal?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="dev-access-secret-change-in-production"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production"

# Server
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:3000"

# S3/MinIO
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="kiroportal"

# SMTP
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@kiroportal.com"

# iTop integration
ITOP_ENABLED=false
ITOP_API_URL="https://itsm.example.com/webservices/rest.php?version=1.3"
# Option 1: token-based auth (preferred)
ITOP_AUTH_TOKEN=""
# Option 2: user/password auth (fallback)
ITOP_USERNAME=""
ITOP_PASSWORD=""
ITOP_TICKET_CLASS=UserRequest
# Organization ID in iTop (required for UserRequest creation)
ITOP_ORG_ID=5

# Sentry
SENTRY_DSN=""
